<?xml version="1.0"?>
<!--
  3-Wheeled Omnidirectional Robot – URDF/Xacro
  =============================================
  Wheel layout (body frame, top view) – MCE402 project report:
    Wheel 1 – α = -60°  → ( 0.10, -0.173)  front-right
    Wheel 2 – α = +60°  → ( 0.10, +0.173)  front-left
    Wheel 3 – α = 180°  → (-0.20,  0.000)  rear

  r = 0.05 m,  L = 0.20 m

  Gazebo plugins (NO gz_ros2_control – uses native Gazebo plugins instead):
    gz-sim-velocity-control-system   → holonomic body motion from /gz_cmd_vel
    gz-sim-odometry-publisher-system → /model/omni_robot/odometry
    gz-sim-joint-controller-system   → wheel spinning (visual)
-->
<robot name="omni_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ─── Constants ─────────────────────────────────────────────────── -->
  <xacro:property name="r_wheel" value="0.05"/>   <!-- wheel radius  [m] -->
  <xacro:property name="w_wheel" value="0.025"/>  <!-- wheel width   [m] -->
  <xacro:property name="L"       value="0.20"/>   <!-- robot radius  [m] -->
  <xacro:property name="r_base"  value="0.13"/>   <!-- body radius   [m]  < L → no overlap -->
  <xacro:property name="h_base"  value="0.08"/>   <!-- body height   [m] -->
  <xacro:property name="m_base"  value="2.0"/>    <!-- body mass     [kg] -->
  <xacro:property name="m_wheel" value="0.25"/>   <!-- wheel mass    [kg] -->

  <!-- ─── Inertia macro ─────────────────────────────────────────────── -->
  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(1.0/12.0)*m*(3*r*r + h*h)}"
        iyy="${(1.0/12.0)*m*(3*r*r + h*h)}"
        izz="${(1.0/2.0)*m*r*r}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ─── Wheel macro ───────────────────────────────────────────────── -->
  <!--
    Wheel cylinder axis (local Z) is rotated to point RADIALLY outward.
    rpy = "pi/2  0  (angle+pi/2)"
      → after Roll pi/2 around X:  local Z  →  world  -Y
      → after Yaw  (a+pi/2):       local Z  →  (cos a, sin a, 0)  [radial]
    So the joint axis "0 0 1" spins the wheel around its own radial axis,
    which is correct for an omni wheel roller motion.

    Wheel centre z in base frame = 0  (same height as body centre).
    Robot spawned at z = r_wheel = 0.05 m  →  wheel bottom = 0 m (ground).
  -->
  <xacro:macro name="omni_wheel" params="name angle_deg">
    <xacro:property name="angle_rad" value="${angle_deg * 3.14159265358979 / 180.0}"/>
    <xacro:property name="wx" value="${L * cos(angle_rad)}"/>
    <xacro:property name="wy" value="${L * sin(angle_rad)}"/>

    <link name="${name}">
      <xacro:cylinder_inertia m="${m_wheel}" r="${r_wheel}" h="${w_wheel}"/>
      <visual>
        <geometry><cylinder radius="${r_wheel}" length="${w_wheel}"/></geometry>
        <material name="wheel_mat"><color rgba="0.1 0.1 0.1 1.0"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="${r_wheel}" length="${w_wheel}"/></geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>      <!-- rolling (tangential) friction -->
              <mu2>0.01</mu2>   <!-- lateral friction ≈ 0 (omni roller) -->
              <fdir1>0 0 0</fdir1>
              <slip1>0.0</slip1>
              <slip2>1.0</slip2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}"/>
      <origin xyz="${wx} ${wy} 0" rpy="${pi/2} 0 ${angle_rad + pi/2}"/>
      <axis xyz="0 0 1"/>
      <dynamics damping="0.005" friction="0.005"/>
    </joint>
  </xacro:macro>

  <!-- ─── Dummy root link (fixes KDL root-inertia warning) ─────────── -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ─── Body ──────────────────────────────────────────────────────── -->
  <link name="base_link">
    <xacro:cylinder_inertia m="${m_base}" r="${r_base}" h="${h_base}"/>
    <visual>
      <geometry><cylinder radius="${r_base}" length="${h_base}"/></geometry>
      <material name="body_mat"><color rgba="0.2 0.5 0.8 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="${r_base}" length="${h_base}"/></geometry>
    </collision>
  </link>

  <!-- ─── Wheels ────────────────────────────────────────────────────── -->
  <xacro:omni_wheel name="wheel_1" angle_deg="-60"/>
  <xacro:omni_wheel name="wheel_2" angle_deg="60"/>
  <xacro:omni_wheel name="wheel_3" angle_deg="180"/>

  <!-- ─── LiDAR ─────────────────────────────────────────────────────── -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry><cylinder radius="0.025" length="0.035"/></geometry>
      <material name="lidar_mat"><color rgba="0.9 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <geometry><cylinder radius="0.025" length="0.035"/></geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="lidar_link"/>
    <origin xyz="0 0 ${h_base/2.0 + 0.0175}" rpy="0 0 0"/>
  </joint>

  <!-- ═══════════════════════════════════════════════════════════════════
       GAZEBO PLUGINS
       No gz_ros2_control (ABI broken in this distro).
       Use native Gazebo 8 (Harmonic) plugins instead.
       ═══════════════════════════════════════════════════════════════════ -->

  <!-- 1. HOLONOMIC VELOCITY CONTROL
       VelocityControl applies cmd in the robot's LOCAL frame  →  perfect omni.
       Subscribes to Gazebo topic /gz_cmd_vel (gz.msgs.Twist).
       Bridged from ROS2 /cmd_vel by parameter_bridge. -->
  <gazebo>
    <plugin filename="gz-sim-velocity-control-system"
            name="gz::sim::systems::VelocityControl">
      <topic>/gz_cmd_vel</topic>
    </plugin>
  </gazebo>

  <!-- 2. ODOMETRY PUBLISHER
       Reads actual model pose from physics → publishes gz.msgs.Odometry.
       Bridged to ROS2 /odom by parameter_bridge. -->
  <gazebo>
    <plugin filename="gz-sim-odometry-publisher-system"
            name="gz::sim::systems::OdometryPublisher">
      <odom_publish_frequency>50</odom_publish_frequency>
      <robot_base_frame>base_link</robot_base_frame>
      <odom_frame>odom</odom_frame>
      <odom_topic>odometry</odom_topic>
    </plugin>
  </gazebo>

  <!-- 3. WHEEL JOINT VELOCITY CONTROLLERS (visual spinning)
       use_force_pid=false → kinematic mode: joint moves at exactly commanded speed.
       Each subscribes to its own Gazebo topic bridged from ROS2 Float64. -->
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>wheel_1_joint</joint_name>
      <topic>/gz_wheel_1_vel</topic>
      <use_force_pid>false</use_force_pid>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>wheel_2_joint</joint_name>
      <topic>/gz_wheel_2_vel</topic>
      <use_force_pid>false</use_force_pid>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin filename="gz-sim-joint-controller-system"
            name="gz::sim::systems::JointController">
      <joint_name>wheel_3_joint</joint_name>
      <topic>/gz_wheel_3_vel</topic>
      <use_force_pid>false</use_force_pid>
    </plugin>
  </gazebo>

  <!-- 4. 2-D LiDAR SENSOR -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_lidar">
      <update_rate>10</update_rate>
      <topic>/scan_gz</topic>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159265</min_angle>
            <max_angle> 3.14159265</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>8.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

</robot>
